<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Project Tracker</title>
  <link rel="stylesheet" href="/css/project-tracker.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="icon" type="image/x-icon" href="/assets/project_tracker.png">
</head>
<body>

  <header class="topbar">
    <div class="logo">
      <h1>Project Tracker</h1>
      <p>Track, manage and deliver projects efficiently</p>
    </div>
    <button class="btn-find" onclick="findProject()">
      <i class="fa-solid fa-magnifying-glass"></i>
      Find Your Project
    </button>
    <div class="user-pill">
      <i class="fa-solid fa-user-astronaut"></i>
      <span>Welcome,<br><label class="user-name" id="userName">Divya Dharshini</label></span>
    </div>
  </header>

  <main class="main-content">
    <div class="project-card">

      <!-- Col 1: Project ID -->
      <div class="proj-id-col">
        <div class="proj-icon">
          <i class="fa-solid fa-file-lines"></i>
        </div>
        <div>
          <div class="proj-id-label">Project ID</div>
          <div class="proj-id-val" id="projectId">AM110-AP</div>
        </div>
        <div class="status-badge">
          <span class="status-dot"></span>
          <span id="projectStatus">Active</span>
        </div>
        <div class="created-row">
          <i class="fa-regular fa-calendar"></i>
          Created at&nbsp;<b><label id="createdAt">14 April 2026</label></b>
        </div>
      </div>

      <!-- Col 2: Dates -->
      <div class="dates-col">
        <div class="date-row">
          <label class="date-label" for="startDate">Starting Date</label>
          <div class="date-input-wrap">
            <input type="date" id="startDate" value="2026-04-14"/>
          </div>
        </div>
        <div class="date-row">
          <label class="date-label" for="reqDate">Customer Req Date</label>
          <div class="date-input-wrap">
            <input type="date" id="reqDate" value="2026-04-30"/>
          </div>
        </div>
        <div class="dates-action">
          <button class="btn-date" onclick="saveDates()">Save Dates</button>
          <span class="saved-msg" id="savedDatesMsg">
            <i class="fa-solid fa-circle-check"></i> Dates saved
          </span>
        </div>
      </div>

      <!-- Col 3: People -->
      <div class="people-col">
        <div class="person-row">
          <span class="person-label">Project Manager</span>
          <div class="person-select-wrap">
            <select id="pmSelect">
              <option>Arun Kumar</option>
              <option>Divya Dharshini</option>
              <option>Sneha Priya</option>
            </select>
          </div>
        </div>
        <div class="person-row">
          <span class="person-label">Quality Manager</span>
          <div class="person-select-wrap">
            <select id="qmSelect">
              <option>Sneha Priya</option>
              <option>Arun Kumar</option>
              <option>Karthik R</option>
            </select>
          </div>
        </div>
        <div class="person-row">
          <span class="person-label">Project Engineer</span>
          <div class="person-select-wrap">
            <select id="peSelect">
              <option>Karthik R</option>
              <option>Arun Kumar</option>
              <option>Divya Dharshini</option>
            </select>
          </div>
        </div>
        <div class="person-row">
          <span class="person-label">Engineer</span>
          <div class="person-select-wrap">
            <select id="engSelect">
              <option>Hariharan S</option>
              <option>Abinaya Sri</option>
              <option>Hansika</option>
            </select>
          </div>
        </div>
        <div class="people-action save-people-btn">
          <button class="btn-save" onclick="savePeople()">Save</button>
          <span class="saved-msg" id="savedPeopleMsg">
            <i class="fa-solid fa-circle-check"></i> Saved
          </span>
        </div>
      </div>
    </div>

    <section class="docs-section">
  <div class="docs-header">
    <div class="docs-title">
      <i class="fa-solid fa-boxes-stacked"></i>
      <h2>Parts & Orders</h2>
    </div>
    <span class="docs-count" id="docsCount">6 parts</span>
  </div>

  <div class="table-wrap">
    <table class="docs-table">
      <thead>
        <tr>
          <th>S.No</th>
          <th>Part Number</th>
          <th>Part Name</th>
          <th>Order Quantity</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="row-num">01</td>
          <td class="part-num">AM-1042</td>
          <td>Hydraulic Cylinder</td>
          <td>12</td>
          <td><span class="status in-progress">In Progress</span></td>
          <td class="actions-cell">
            <button class="btn-action view" onclick="viewPart(this)"><i class="fa-solid fa-list-check"></i> View</button>
          </td>
        </tr>
        <tr>
          <td class="row-num">02</td>
          <td class="part-num">AM-2087</td>
          <td>Bearing Housing</td>
          <td>30</td>
          <td><span class="status completed">Completed</span></td>
          <td class="actions-cell">
            <button class="btn-action view" onclick="viewPart(this)"><i class="fa-solid fa-list-check"></i> View</button>
          </td>
        </tr>
        <tr>
          <td class="row-num">03</td>
          <td class="part-num">AM-3310</td>
          <td>Shaft Coupling</td>
          <td>8</td>
          <td><span class="status pending">Pending </span></td>
          <td class="actions-cell">
            <button class="btn-action view" onclick="viewPart(this)"><i class="fa-solid fa-list-check"></i> </i>View</button>
          </td>
        </tr>
        <tr>
          <td class="row-num">04</td>
          <td class="part-num">AM-4455</td>
          <td>Flange Bolt Set</td>
          <td>100</td>
          <td><span class="status on-hold">On Hold</span></td>
          <td class="actions-cell">
            <button class="btn-action view" onclick="viewPart(this)"><i class="fa-solid fa-list-check"></i>  View</button>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</section>
</main>

  <!-- RIGHT SIDE VIEW PANEL -->
   <div class="overlay" id="overlay"></div>
<div class="view-panel" id="viewPanel">
  <div class="view-panel-content">

    <div class="view-header">
  <h3>Part Details</h3>

  <div class="header-icons">
    <i class="fa-solid fa-clone"></i>
    <i class="fa-solid fa-share"></i>
    <i class="fa-solid fa-xmark close-icon" onclick="closePanel()"></i>
  </div>
</div>

<div class="view-body">

  <!-- TOP DETAILS -->
  <div class="part-top">
    <div class="part-col">
      <label>Part Name: </label>
      <p id="partName">-</p>
    </div>

    <div class="part-col">
      <label>Order Quantity: </label>
      <p id="partQty">-</p>
    </div>

    <div class="part-col">
  <label>Upload File: </label>

  <span class="stage-upload-trigger part-files-text">
    Part Files (<span class="file-count">0</span>)
  </span>
</div>
</div>

<div class="tabs">
          <button class="tab active" data-tab="stage">Stages</button>
          <button class="tab" data-tab="document">Documents</button>
        </div>


 <!-- TABS -->

        <!-- STAGES TAB -->
        <div id="stage" class="tab-content active">

          <!-- STAGE 1: DFM Checking — 2 rows -->
          <div class="stage-section" id="section-dfm">
            <div class="stage-section-header">
              <span class="stage-section-title">DFM Checking</span>
              <button class="btn-add" onclick="addRow('tbody-dfm', getVerifiers())">
                <i class="fa-solid fa-plus"></i> Add
              </button>
            </div>
            <div class="stage-table-wrap">
              <table class="stage-tbl">
                <thead>
                  <tr>
                    <th>Stage</th>
                    <th>Target Date</th>
                    <th>Actual Date</th>
                    <th>Inward</th>
                    <th>Outward</th>
                    <th>Upload</th>
                    <th>Verifier</th>
                    <th>Remarks</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody id="tbody-dfm">
                  <!-- 2 default rows for DFM -->
                </tbody>
              </table>
            </div>
            <div class="stage-footer">
              <button class="btn-close-section" onclick="toggleSection('section-dfm')">
                Close Section <i class="fa-solid fa-arrow-up"></i>
              </button>
            </div>
          </div>

          <!-- STAGE 2: Manufacturing — 1 row -->
          <div class="stage-section" id="section-mfg">
            <div class="stage-section-header">
              <span class="stage-section-title">Manufacturing</span>
              <button class="btn-add" onclick="addRow('tbody-mfg', getVerifiers())">
                <i class="fa-solid fa-plus"></i> Add
              </button>
            </div>
            <div class="stage-table-wrap">
              <table class="stage-tbl">
                <thead>
                  <tr>
                    <th>Stage</th>
                    <th>Target Date</th>
                    <th>Actual Date</th>
                    <th>Inward</th>
                    <th>Outward</th>
                    <th>Upload</th>
                    <th>Verifier</th>
                    <th>Remarks</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody id="tbody-mfg">
                </tbody>
              </table>
            </div>
            <div class="stage-footer">
              <button class="btn-close-section" onclick="toggleSection('section-mfg')">
                Close Section <i class="fa-solid fa-arrow-up"></i>
              </button>
            </div>
          </div>

          <!-- STAGE 3: Inspection — 1 row -->
          <div class="stage-section" id="section-insp">
            <div class="stage-section-header">
              <span class="stage-section-title">Inspection</span>
              <button class="btn-add" onclick="addRow('tbody-insp', getVerifiers())">
                <i class="fa-solid fa-plus"></i> Add
              </button>
            </div>
            <div class="stage-table-wrap">
              <table class="stage-tbl">
                <thead>
                  <tr>
                    <th>Stage</th>
                    <th>Target Date</th>
                    <th>Actual Date</th>
                    <th>Inward</th>
                    <th>Outward</th>
                    <th>Upload</th>
                    <th>Verifier</th>
                    <th>Remarks</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody id="tbody-insp">
                </tbody>
              </table>
            </div>
            <div class="stage-footer">
              <button class="btn-close-section" onclick="toggleSection('section-insp')">
                Close Section <i class="fa-solid fa-arrow-up"></i>
              </button>
            </div>
          </div>

          <!-- STAGE 4: Dispatch — 1 row -->
          <div class="stage-section" id="section-disp">
            <div class="stage-section-header">
              <span class="stage-section-title">Dispatch</span>
              <button class="btn-add" onclick="addRow('tbody-disp', getVerifiers())">
                <i class="fa-solid fa-plus"></i> Add
              </button>
            </div>
            <div class="stage-table-wrap">
              <table class="stage-tbl">
                <thead>
                  <tr>
                    <th>Stage</th>
                    <th>Target Date</th>
                    <th>Actual Date</th>
                    <th>Inward</th>
                    <th>Outward</th>
                    <th>Upload</th>
                    <th>Verifier</th>
                    <th>Remarks</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody id="tbody-disp">
                </tbody>
              </table>
            </div>
            <div class="stage-footer">
              <button class="btn-close-section" onclick="toggleSection('section-disp')">
                Close Section <i class="fa-solid fa-arrow-up"></i>
              </button>
            </div>
          </div>

        </div><!-- /stage tab -->

        <!-- DOCUMENTS TAB -->
        <div id="document" class="tab-content">
          <div id="documentsContainer"></div>
        </div>

    </div>
  </div>

  <!-- ===== ADDED: REMARKS POPUP (positioned near clicked field via JS) ===== -->
  <div id="remarksOverlay" class="remarks-overlay-bg"></div>
  <div id="remarksPopup" style="height: 140px;" class="remarks-popup">
    <textarea id="remarksText" placeholder="Enter remarks..."></textarea>
    <div class="remarks-popup-actions">
      <button class="remarks-btn-cancel" onclick="closeRemarksPopup()">Cancel</button>
      <button class="remarks-btn-save" onclick="saveRemarks()">Save</button>
    </div>
  </div>

  <!-- ===== ADDED: UPLOAD FILES POPUP ===== -->
  <div class="upload-popup-overlay" id="uploadPopupOverlay" onclick="closeUploadPopup()"></div>
  <div class="upload-popup" id="uploadPopup">
    <div class="upload-popup-header">
      <div class="upload-popup-title">
        <i class="fa-solid fa-folder-open"></i>
        <span>Project Files</span>
      </div>
      <i class="fa-solid fa-xmark upload-popup-close" onclick="closeUploadPopup()"></i>
    </div>
    <div class="upload-popup-body">
      <div class="upload-drop-zone" onclick="document.getElementById('stageFilePicker').click()">
        <i class="fa-solid fa-cloud-arrow-up"></i>
        <p>Click to choose files</p>
        <span>PDF, DWG, XLSX, images and more</span>
      </div>
      <input type="file" id="stageFilePicker" multiple style="display:none;" onchange="handleStageFiles(this)" />
      <table class="upload-files-table">
        <thead>
          <tr>
            <th>File Name</th>
            <th>File Type</th>
            <th>Remarks</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="uploadFilesTbody">
          <tr id="uploadEmptyRow">
            <td colspan="4" class="upload-empty-cell">No files added yet</td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="upload-popup-footer">
      <button class="upload-btn-cancel" onclick="closeUploadPopup()">Cancel</button>
      <button class="upload-btn-insert" onclick="insertStageFiles()">
        <i class="fa-solid fa-circle-check"></i> Insert Files
      </button>
    </div>
  </div>

  <!-- ===== ADDED: FIND PROJECT MODAL ===== -->
  <div class="find-modal-overlay" id="findModalOverlay" onclick="closeFindModal()"></div>
  <div class="find-modal" id="findModal">
    <div class="find-modal-top">
      <div class="find-modal-icon-wrap">
        <i class="fa-solid fa-magnifying-glass"></i>
      </div>
      <h2>Find Your Project</h2>
      <p>Enter a project ID to view progress and updates</p>
    </div>
    <div class="find-modal-body">
      <input type="text" id="findModalInput" class="find-modal-input" placeholder="Enter here..."
             onkeydown="if(event.key==='Enter') doFindProject()" />
      <p class="find-modal-error" id="findModalError"></p>
      <button class="find-modal-search-btn" onclick="doFindProject()">
        <i class="fa-solid fa-magnifying-glass"></i> Search
      </button>
      <button class="find-modal-cancel-btn" onclick="closeFindModal()">Cancel</button>
    </div>
  </div>

  <script src="/js/project-tracker.js"></script>
</body>
</html>
